LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# Singapore app server: keep data/model files off the app host and proxy model work to London.
# Leave FINTERRA_MODEL_API_BASE_URL empty on local development to keep using local data/ and local model params.
FINTERRA_MODEL_API_BASE_URL=https://your-london-model-api.example.com
FINTERRA_MODEL_API_KEY=replace_with_a_long_random_shared_secret
FINTERRA_MODEL_API_TIMEOUT_MS=120000

# London model server only: require the Singapore app server to send this key.
# Do not set FINTERRA_MODEL_API_BASE_URL on the London model server.
FINTERRA_MODEL_API_SERVER_KEY=replace_with_the_same_long_random_shared_secret
